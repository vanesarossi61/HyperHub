generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Enums
// ============================================================

enum BatteryLevel {
  GREEN
  YELLOW
  RED
  LURKER
}

enum ToneTag {
  ENTHUSIASM
  RANT
  DEBATE
  INFO_DUMP
  QUESTION
  HELP
}

enum NeurodivType {
  ADHD_INATTENTIVE
  ADHD_HYPERACTIVE
  ADHD_COMBINED
  AUTISM
  DYSLEXIA
  DYSCALCULIA
  DYSPRAXIA
  TOURETTE
  OCD
  BIPOLAR
  ANXIETY
  DEPRESSION
  SENSORY_PROCESSING
  OTHER
  PREFER_NOT_TO_SAY
}

enum AnimationTolerance {
  NONE
  MINIMAL
  MODERATE
  FULL
}

enum InfoDensity {
  COMPACT
  COMFORTABLE
  SPACIOUS
}

enum ContrastMode {
  DEFAULT
  HIGH
  MUTED
  DARK_FOCUS
}

enum OnboardingStep {
  BASICS
  HYPERFOCI
  SENSORY
  BATTERY_TUTORIAL
  COMPLETED
}

// Phase 3 Enums

enum ReactionType {
  ME_TOO
  BRAIN_EXPLODE
  HYPERFOCUS_ACTIVATED
  GENTLE_HUG
  INFO_GOLD
}

enum Visibility {
  PUBLIC
  FOLLOWERS
  HYPERFOCUS_GROUP
  PRIVATE
}

// ============================================================
// User Model
// ============================================================

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  username  String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile            Profile?
  sensoryPreferences SensoryPreferences?
  socialBattery      SocialBattery?
  batteryHistory     BatteryHistory[]

  // Phase 3 relations
  posts              Post[]
  reactions          Reaction[]
  bookmarks          Bookmark[]
  bookmarkFolders    BookmarkFolder[]

  @@index([clerkId])
  @@index([email])
}

// ============================================================
// Profile Model (Expanded for Phase 2)
// ============================================================

model Profile {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String?
  bio         String?
  avatarUrl   String?

  pronouns    String?
  ageRange    String?
  timezone    String?
  languages   String[]

  neurodivTypes      NeurodivType[]
  selfDiagnosed      Boolean        @default(false)
  diagnosisOptional  String?
  comfortTopics      String[]
  triggerWarnings    String[]
  communicationStyle String?
  currentMood        String?

  hyperfocusHistory String[]
  currentHyperfoci  String[]

  onboardingStep      OnboardingStep @default(BASICS)
  onboardingCompleted Boolean        @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// Sensory Preferences (Expanded for Phase 2)
// ============================================================

model SensoryPreferences {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  colorPalette        ContrastMode       @default(DEFAULT)
  animationTolerance  AnimationTolerance @default(MINIMAL)
  informationDensity  InfoDensity        @default(COMFORTABLE)
  transitionSpeed     String             @default("normal")
  fontScale           Float              @default(1.0)
  reducedMotion       Boolean            @default(true)

  bionicReadingEnabled Boolean @default(false)
  dyslexicFontEnabled  Boolean @default(false)
  lineSpacing          String  @default("normal")

  notificationIntensity String  @default("gentle")
  soundEnabled          Boolean @default(false)
  hapticEnabled         Boolean @default(true)

  activePreset String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// Social Battery (Expanded for Phase 2)
// ============================================================

model SocialBattery {
  id     String       @id @default(cuid())
  userId String       @unique
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  level  BatteryLevel @default(GREEN)

  manualOverride    Boolean @default(false)
  autoDecayEnabled  Boolean @default(true)
  decayRateMinutes  Int     @default(120)
  rechargeReminders Boolean @default(true)

  autoLurkerStart String?
  autoLurkerEnd   String?

  lastLevelChange DateTime @default(now())
  lastActivity    DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// Battery History (Phase 2)
// ============================================================

model BatteryHistory {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromLevel BatteryLevel
  toLevel   BatteryLevel
  reason    String       @default("manual")
  createdAt DateTime     @default(now())

  @@index([userId, createdAt])
}

// ============================================================
// Post (New - Phase 3)
// ============================================================

model Post {
  id        String   @id @default(cuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  content     String
  toneTag     ToneTag
  visibility  Visibility @default(PUBLIC)
  isAnonymous Boolean    @default(false)

  mediaUrls   String[]
  audioUrl    String?

  tldrText       String?
  tldrGeneratedAt DateTime?

  readingTimeSeconds Int @default(0)
  wordCount          Int @default(0)

  viewCount     Int @default(0)
  reactionCount Int @default(0)
  bookmarkCount Int @default(0)

  postTags   PostTag[]
  reactions  Reaction[]
  bookmarks  Bookmark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId, createdAt])
  @@index([toneTag, createdAt])
  @@index([visibility, createdAt])
}

// ============================================================
// Tag (New - Phase 3)
// ============================================================

model Tag {
  id         String   @id @default(cuid())
  name       String   @unique
  category   String?
  usageCount Int      @default(0)

  postTags PostTag[]

  createdAt DateTime @default(now())

  @@index([name])
  @@index([usageCount])
}

// ============================================================
// PostTag Junction (New - Phase 3)
// ============================================================

model PostTag {
  id     String @id @default(cuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([postId, tagId])
  @@index([tagId])
}

// ============================================================
// Reaction (New - Phase 3)
// ============================================================

model Reaction {
  id     String       @id @default(cuid())
  postId String
  post   Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   ReactionType

  createdAt DateTime @default(now())

  @@unique([postId, userId, type])
  @@index([postId])
  @@index([userId])
}

// ============================================================
// Bookmark (New - Phase 3)
// ============================================================

model Bookmark {
  id       String  @id @default(cuid())
  postId   String
  post     Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  folderId String?
  folder   BookmarkFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([userId, createdAt])
  @@index([folderId])
}

// ============================================================
// BookmarkFolder (New - Phase 3)
// ============================================================

model BookmarkFolder {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
  emoji  String?

  bookmarks Bookmark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}
