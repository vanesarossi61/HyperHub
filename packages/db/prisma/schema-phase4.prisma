generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Enums
// ============================================================

enum BatteryLevel {
  GREEN
  YELLOW
  RED
  LURKER
}

enum ToneTag {
  ENTHUSIASM
  RANT
  DEBATE
  INFO_DUMP
  QUESTION
  HELP
}

enum NeurodivType {
  ADHD_INATTENTIVE
  ADHD_HYPERACTIVE
  ADHD_COMBINED
  AUTISM
  DYSLEXIA
  DYSCALCULIA
  DYSPRAXIA
  TOURETTE
  OCD
  BIPOLAR
  ANXIETY
  DEPRESSION
  SENSORY_PROCESSING
  OTHER
  PREFER_NOT_TO_SAY
}

enum AnimationTolerance {
  NONE
  MINIMAL
  MODERATE
  FULL
}

enum InfoDensity {
  COMPACT
  COMFORTABLE
  SPACIOUS
}

enum ContrastMode {
  DEFAULT
  HIGH
  MUTED
  DARK_FOCUS
}

enum OnboardingStep {
  BASICS
  HYPERFOCI
  SENSORY
  BATTERY_TUTORIAL
  COMPLETED
}

enum ReactionType {
  SAME_HERE
  BRAIN_EXPLODE
  HYPERFOCUS
  SPOON_GIFT
  INFODUMP_THANKS
  HUG
  SENSORY_OVERLOAD
}

enum Visibility {
  PUBLIC
  FRIENDS_ONLY
  PRIVATE
}

// Phase 4 Enums
enum ConversationType {
  DIRECT        // 1:1 chat
  GROUP         // Group chat (2-8 people)
  SAFE_SPACE    // Moderated safe space channel
}

enum MessageStatus {
  QUEUED        // In battery queue (recipient RED/LURKER)
  DELIVERED     // Delivered to recipient
  READ          // Read by recipient
  FAILED        // Delivery failed
}

enum ParticipantRole {
  OWNER         // Created the conversation
  ADMIN         // Can manage participants
  MEMBER        // Regular participant
}

enum SafeExitReason {
  NEED_BREAK        // "Necesito tomar una pausa"
  SENSORY_OVERLOAD  // "Sobrecarga sensorial"
  LOW_BATTERY       // Auto-triggered by battery RED
  OVERWHELMED       // "Me siento abrumado/a"
  CUSTOM            // Custom reason
}

enum NotificationPriority {
  SILENT    // No notification at all
  LOW       // Badge only, no sound/vibration
  NORMAL    // Standard notification
  URGENT    // Override DND for safety messages
}

// ============================================================
// User Model (Updated for Phase 4)
// ============================================================

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  username  String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile            Profile?
  sensoryPreferences SensoryPreferences?
  socialBattery      SocialBattery?
  batteryHistory     BatteryHistory[]
  posts              Post[]
  comments           Comment[]
  reactions          Reaction[]
  bookmarks          Bookmark[]

  // Phase 4: Messaging relations
  conversationParticipants ConversationParticipant[]
  sentMessages             Message[]
  messageReads             MessageRead[]
  safeExits                SafeExit[]
  notificationPrefs        NotificationPreference?

  @@index([clerkId])
  @@index([email])
}

// ============================================================
// Profile Model (Phase 2)
// ============================================================

model Profile {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String?
  bio         String?
  avatarUrl   String?

  pronouns    String?
  ageRange    String?
  timezone    String?
  languages   String[]

  neurodivTypes      NeurodivType[]
  selfDiagnosed      Boolean        @default(false)
  diagnosisOptional  String?
  comfortTopics      String[]
  triggerWarnings    String[]
  communicationStyle String?
  currentMood        String?

  hyperfocusHistory String[]
  currentHyperfoci  String[]

  onboardingStep      OnboardingStep @default(BASICS)
  onboardingCompleted Boolean        @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// Sensory Preferences (Phase 2)
// ============================================================

model SensoryPreferences {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  colorPalette        ContrastMode       @default(DEFAULT)
  animationTolerance  AnimationTolerance @default(MINIMAL)
  informationDensity  InfoDensity        @default(COMFORTABLE)
  transitionSpeed     String             @default("normal")
  fontScale           Float              @default(1.0)
  reducedMotion       Boolean            @default(true)

  bionicReadingEnabled Boolean @default(false)
  dyslexicFontEnabled  Boolean @default(false)
  lineSpacing          String  @default("normal")

  notificationIntensity String  @default("gentle")
  soundEnabled          Boolean @default(false)
  hapticEnabled         Boolean @default(true)

  activePreset String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// Social Battery (Phase 2)
// ============================================================

model SocialBattery {
  id     String       @id @default(cuid())
  userId String       @unique
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  level  BatteryLevel @default(GREEN)

  manualOverride    Boolean @default(false)
  autoDecayEnabled  Boolean @default(true)
  decayRateMinutes  Int     @default(120)
  rechargeReminders Boolean @default(true)

  autoLurkerStart String?
  autoLurkerEnd   String?

  lastLevelChange DateTime @default(now())
  lastActivity    DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// Battery History (Phase 2)
// ============================================================

model BatteryHistory {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromLevel BatteryLevel
  toLevel   BatteryLevel
  reason    String       @default("manual")
  createdAt DateTime     @default(now())

  @@index([userId, createdAt])
}

// ============================================================
// Post Model (Phase 3)
// ============================================================

model Post {
  id       String @id @default(cuid())
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  title   String?
  content String   @db.Text
  toneTag ToneTag

  hyperfoci    String[]
  wordCount    Int        @default(0)
  isInfoDump   Boolean    @default(false)
  tldrSummary  String?    @db.Text
  visibility   Visibility @default(PUBLIC)

  published Boolean @default(true)
  pinned    Boolean @default(false)

  comments  Comment[]
  reactions Reaction[]
  bookmarks Bookmark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
  @@index([toneTag])
  @@index([published, createdAt])
  @@index([pinned, createdAt])
}

// ============================================================
// Comment Model (Phase 3)
// ============================================================

model Comment {
  id       String @id @default(cuid())
  postId   String
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  content String  @db.Text
  toneTag ToneTag?

  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies  Comment[] @relation("CommentReplies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, createdAt])
  @@index([authorId])
  @@index([parentId])
}

// ============================================================
// Reaction Model (Phase 3)
// ============================================================

model Reaction {
  id     String       @id @default(cuid())
  postId String
  post   Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   ReactionType

  createdAt DateTime @default(now())

  @@unique([postId, userId, type])
  @@index([postId])
  @@index([userId])
}

// ============================================================
// Bookmark Model (Phase 3)
// ============================================================

model Bookmark {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  folder    String?
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([userId, createdAt])
}

// ============================================================
// Phase 4: Conversation Model
// ============================================================

model Conversation {
  id   String           @id @default(cuid())
  type ConversationType @default(DIRECT)

  // Group metadata (null for DIRECT)
  name        String?  // Group name
  description String?  // Group description
  avatarUrl   String?  // Group avatar
  maxMembers  Int      @default(2) // 2 for DIRECT, up to 8 for GROUP

  // Tone tag requirement -- every message must have one
  toneTagRequired Boolean @default(true)

  // Safe space settings
  slowModeSeconds  Int     @default(0) // 0 = disabled, >0 = min seconds between messages
  contentWarnings  Boolean @default(false) // Require CW on messages

  // Status
  isActive  Boolean  @default(true)
  lastMessageAt DateTime?

  // Relations
  participants ConversationParticipant[]
  messages     Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isActive, lastMessageAt])
}

// ============================================================
// Phase 4: Conversation Participant
// ============================================================

model ConversationParticipant {
  id             String          @id @default(cuid())
  conversationId String
  conversation   Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           ParticipantRole @default(MEMBER)

  // Notification preferences per conversation
  muted         Boolean @default(false)
  pinned        Boolean @default(false)

  // Nickname within this conversation
  nickname      String?

  // Tracking
  lastReadAt    DateTime?
  joinedAt      DateTime @default(now())
  leftAt        DateTime? // null = still in conversation

  @@unique([conversationId, userId])
  @@index([userId, leftAt]) // Find active conversations for a user
  @@index([conversationId])
}

// ============================================================
// Phase 4: Message Model
// ============================================================

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  // Content
  content   String        @db.Text
  toneTag   ToneTag       // Required: every message has a tone tag

  // Delivery
  status    MessageStatus @default(DELIVERED)

  // Reply threading
  replyToId String?
  replyTo   Message?      @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[]     @relation("MessageReplies")

  // Metadata
  editedAt  DateTime?
  isSystem  Boolean       @default(false) // System messages (join, leave, safe exit)

  // Relations
  reads     MessageRead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([status])
  @@index([replyToId])
}

// ============================================================
// Phase 4: Message Read Receipt
// ============================================================

model MessageRead {
  id        String  @id @default(cuid())
  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt    DateTime @default(now())

  @@unique([messageId, userId])
  @@index([userId, readAt])
}

// ============================================================
// Phase 4: Safe Exit Log
// ============================================================

model SafeExit {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversationId String?         // null = exited all conversations
  reason         SafeExitReason
  customMessage  String?         // If reason is CUSTOM
  autoMessage    String          // Message shown to others: "[User] necesita una pausa"

  // Duration
  exitedAt       DateTime        @default(now())
  returnedAt     DateTime?       // null = still on break
  plannedReturn  DateTime?       // Optional: "Vuelvo en 30 min"

  @@index([userId, exitedAt])
  @@index([conversationId])
}

// ============================================================
// Phase 4: Notification Preferences (per user global)
// ============================================================

model NotificationPreference {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Battery-adaptive delivery
  greenBattery   NotificationPriority @default(NORMAL)
  yellowBattery  NotificationPriority @default(LOW)
  redBattery     NotificationPriority @default(SILENT)
  lurkerBattery  NotificationPriority @default(SILENT)

  // Quiet hours
  quietHoursEnabled Boolean  @default(false)
  quietHoursStart   String?  // "22:00"
  quietHoursEnd     String?  // "08:00"

  // Digest mode -- batch notifications instead of real-time
  digestEnabled     Boolean  @default(false)
  digestIntervalMin Int      @default(30) // Minutes between digests

  // Per-type toggles
  newMessageEnabled   Boolean @default(true)
  mentionEnabled      Boolean @default(true)
  reactionEnabled     Boolean @default(true)
  safeExitEnabled     Boolean @default(true) // Notify when someone safe-exits

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
